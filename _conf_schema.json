{
  "enabled": {
    "description": "是否启用TTS文本过滤功能",
    "type": "bool",
    "default": true
  },
  "max_length": {
    "description": "最大朗读字数（超过此字数跳过朗读，防止token浪费，0表示无限制）",
    "type": "int",
    "default": 200,
    "hint": "范围：0-1000"
  },
  "max_processing_length": {
    "description": "最大处理文本长度（超过此长度跳过过滤，防止正则处理超长文本卡顿）",
    "type": "int",
    "default": 10000,
    "hint": "范围：1000-50000"
  },
  "remove_patterns": {
    "description": "正则过滤规则（匹配到的内容会被删除，一行一个正则表达式）",
    "type": "list",
    "items": { "type": "string" },
    "default": [
      "[（(][^（()]*[）)]",
      "[＞>][＿_][＜<]",
      "[＾^][＿_][＾^]",
      "[oO][＿_][oO]",
      "[xX][＿_][xX]",
      "[－-][＿_][－-]",
      "[★☆♪♫♬♩♡♥❤️💖💕💗💓💝💟💜💛💚💙🧡🤍🖤🤎💔❣️💋]",
      "[→←↑↓↖↗↘↙↔↕↺↻]"
    ]
  },
  "filter_words": {
    "description": "直接过滤的字符和词汇（会被TTS朗读出怪声的符号、颜文字用字、网络用语等）",
    "type": "list",
    "items": { "type": "string" },
    "default": [
      "ω", "Ω",
      "σ", "Σ",
      "ε",
      "д", "Д",
      "´", "`",
      "＝",
      "∀", "∇",
      "orz", "OTZ",
      "QAQ", "QWQ", "TAT", "TUT",
      "www"
    ]
  },
  "replacement_words": {
    "description": "替换词汇配置（格式：原词|替换词，一行一个）",
    "type": "list",
    "items": { "type": "string" },
    "default": [
      "233|哈哈哈",
      "666|厉害",
      "999|很棒",
      "555|呜呜呜"
    ]
  },
  "max_repeat_count": {
    "description": "重复字符压缩：保留的最大重复数量（如设为2，哈哈哈哈→哈哈），设为0关闭此功能",
    "type": "int",
    "default": 2,
    "hint": "范围：0-5，0=关闭"
  },
  "debug_mode": {
    "description": "是否启用调试模式，在日志中显示每次过滤的详细对比",
    "type": "bool",
    "default": false
  }
}